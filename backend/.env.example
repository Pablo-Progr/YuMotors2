# Configuración del servidor de correo para recuperación de contraseñas
# Para Gmail, debes generar una contraseña de aplicación:
# 1. Ve a tu cuenta de Google
# 2. Seguridad > Verificación en 2 pasos (debe estar activada)
# 3. Contraseñas de aplicaciones > Seleccionar app (Correo) > Generar
# 4. Usa la contraseña generada aquí

EMAIL_USER=tucorreo@gmail.com
EMAIL_PASS=tu_contraseña_de_aplicacion
